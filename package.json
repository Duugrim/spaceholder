{
  "name": "spaceholder",
  "version": "2.1.0",
  "description": "CSS compiler for the SpaceHolder system",
  "scripts": {
    "build": "sass src/scss/spaceholder.scss css/spaceholder.css --style=expanded --no-source-map",
    "watch": "sass src/scss/spaceholder.scss css/spaceholder.css --style=expanded --source-map --watch",
    "pack:sh-test-items": "node scripts/compile-sh-test-items.mjs --in-place",
    "pack:sh-test-items:next": "node scripts/compile-sh-test-items.mjs",
    "unpack:sh-test-items": "npx --yes @foundryvtt/foundryvtt-cli package unpack -n sh-test-items --inputDirectory ./packs --outputDirectory ./pack-src/sh-test-items -c"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Asacolips",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "sass": "^1.53.0"
  }
}
