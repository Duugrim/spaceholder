<div class="inventory-panel" data-sh-root-inventory-drop="1">
  <div class="inventory-layout">
    <aside class="inventory-preview-column">
      {{#if selectedInventoryRow}}
        <article class="inventory-preview-card">
          <div class="inventory-preview-top">
            <div class="inventory-preview-visual">
              <div class="inventory-preview-visual__side inventory-preview-visual__side--left">
                <div class="inventory-preview-gauge-placeholder" aria-hidden="true"></div>
              </div>
              <div class="inventory-preview-visual__center">
                <div class="inventory-preview-image-frame">
                  <img
                    class="inventory-preview-image"
                    src="{{selectedInventoryRow.img}}"
                    title="{{selectedInventoryRow.name}}"
                    alt="{{selectedInventoryRow.name}}"
                  />
                </div>
              </div>
              <div class="inventory-preview-visual__side inventory-preview-visual__side--right">
                {{#if selectedInventoryRow.previewGauges.showOverflowHint}}
                  <div
                    class="inventory-preview-gauge-overflow"
                    title="{{localize 'SPACEHOLDER.Inventory.PreviewGauge.OverflowHint'}}"
                    aria-label="{{localize 'SPACEHOLDER.Inventory.PreviewGauge.OverflowHint'}}"
                  >
                    <i class="fas fa-chevron-down"></i>
                  </div>
                {{else if selectedInventoryRow.previewGauges.verticalGauges.length}}
                  <div class="inventory-preview-gauges inventory-preview-gauges--vertical">
                    {{#each selectedInventoryRow.previewGauges.verticalGauges as |gauge|}}
                      <div
                        class="inventory-preview-gauge"
                        title="{{gauge.label}} {{gauge.current}}/{{gauge.max}}"
                      >
                        <div class="inventory-preview-gauge__track">
                          <div
                            class="inventory-preview-gauge__fill"
                            style="--sh-gauge-percent: {{gauge.percent}};"
                          ></div>
                        </div>
                      </div>
                    {{/each}}
                  </div>
                {{/if}}
              </div>
            </div>

            {{#if selectedInventoryRow.previewGauges.showOverflowHint}}
              <div class="inventory-preview-gauges-horizontal">
                {{#each selectedInventoryRow.previewGauges.horizontalGroups as |group|}}
                  <div class="inventory-preview-gauge-group">
                    <div class="inventory-preview-gauge-group__label">{{group.lineLabel}}</div>
                    <div class="inventory-preview-gauges inventory-preview-gauges--horizontal">
                      {{#each group.gauges as |gauge|}}
                        <div
                          class="inventory-preview-gauge"
                          title="{{gauge.label}} {{gauge.current}}/{{gauge.max}}"
                        >
                          <div class="inventory-preview-gauge__track">
                            <div
                              class="inventory-preview-gauge__fill"
                              style="--sh-gauge-percent: {{gauge.percent}};"
                            ></div>
                          </div>
                        </div>
                      {{/each}}
                    </div>
                  </div>
                {{/each}}
              </div>
            {{/if}}

            <div class="inventory-preview-title">
              <h3>{{selectedInventoryRow.name}}</h3>
              {{#if selectedInventoryRow.isSnapshot}}
                <span class="item-storage-kind">{{localize 'SPACEHOLDER.Inventory.NestedStorageItem'}}</span>
              {{/if}}
            </div>
          </div>

          <div class="inventory-preview-meta">
            <span>{{localize 'SPACEHOLDER.Inventory.Quantity'}} {{selectedInventoryRow.quantity}}</span>
            <span>{{localize 'SPACEHOLDER.Resources.Weight'}} {{selectedInventoryRow.totalWeight}} {{localize 'SPACEHOLDER.Units.Kg'}}</span>
          </div>

          <div class="item-controls inventory-preview-controls">
            {{#if selectedInventoryRow.canHold}}
            <button
              type="button"
              class="icon-btn item-held-toggle {{#if selectedInventoryRow.system.held}}active{{/if}}"
              title="{{#if selectedInventoryRow.system.held}}{{localize 'SPACEHOLDER.ActionsSystem.Wearable.StowShort'}}{{else}}{{localize 'SPACEHOLDER.ActionsSystem.Wearable.HoldShort'}}{{/if}}"
              data-item-id="{{selectedInventoryRow.itemId}}"
              data-action="item-held-toggle"
            >
              <i class="fa-solid fa-hand"></i>
            </button>
            {{/if}}
            {{#if selectedInventoryRow.canEquipArmor}}
            <button
              type="button"
              class="icon-btn item-wearable-toggle {{#if selectedInventoryRow.system.equipped}}active{{/if}}"
              title="{{localize 'SPACEHOLDER.Wearable.EquipToggleTooltip'}}"
              data-item-id="{{selectedInventoryRow.itemId}}"
              data-action="wearable-toggle"
            >
              <i class="fas fa-shield-alt"></i>
            </button>
            {{/if}}
            {{#if selectedInventoryRow.canEdit}}
            <button
              type="button"
              class="icon-btn item-edit"
              title="{{localize 'SPACEHOLDER.Inventory.EditItem'}}"
              data-item-id="{{selectedInventoryRow.itemId}}"
            >
              <i class="fas fa-edit"></i>
            </button>
            {{/if}}
            {{#if selectedInventoryRow.canDelete}}
            <button
              type="button"
              class="icon-btn item-delete"
              title="{{localize 'SPACEHOLDER.Inventory.DeleteItem'}}"
              data-item-id="{{selectedInventoryRow.itemId}}"
            >
              <i class="fas fa-trash"></i>
            </button>
            {{/if}}
          </div>

          <div class="inventory-preview-description">
            {{{selectedInventoryRow.enrichedDescription}}}
          </div>
        </article>
      {{else}}
        <div class="inventory-preview-empty">
          <i class="fas fa-box-open"></i>
          <p><em>{{localize 'SPACEHOLDER.Inventory.Empty'}}</em></p>
        </div>
      {{/if}}
    </aside>

    <section class="inventory-list-column">
      <div class='inventory-list'>
        {{#each inventoryRows as |row|}}
          <div
            class='inventory-item-card{{#if row.depth}} inventory-item-card--nested{{/if}}{{#if row.isSnapshot}} inventory-item-card--storage-snapshot{{/if}}{{#if row.tagClass}} {{row.tagClass}}{{/if}}{{#if row.isHeld}} inventory-item-card--held{{/if}}{{#if row.isSelected}} is-selected{{/if}}'
            data-action="inventory-row-select"
            data-inventory-row-key='{{row.key}}'
            {{#if row.itemId}}data-item-id='{{row.itemId}}'{{/if}}
            {{#if row.canDropContainer}}data-sh-inventory-container-drop="1"{{/if}}
            style='--sh-inv-depth: {{row.depth}};{{#if row.tagStyle}} {{row.tagStyle}}{{/if}}'
            role="button"
            tabindex="0"
          >
            <div class='item-main'>
              <div class='item-image'>
                {{#if row.isDocument}}
                <a class='rollable' data-roll-type='item'>
                  <img
                    src='{{row.img}}'
                    title='{{row.name}}'
                    width='48'
                    height='48'
                  />
                </a>
                {{else}}
                  <img
                    src='{{row.img}}'
                    title='{{row.name}}'
                    width='48'
                    height='48'
                  />
                {{/if}}
              </div>
              <div class='item-info'>
                <div class='item-name'>{{row.displayName}}</div>
                {{#if row.isSnapshot}}
                  <div class='item-details'>
                    <span class='item-storage-kind'>{{localize 'SPACEHOLDER.Inventory.NestedStorageItem'}}</span>
                  </div>
                {{/if}}
              </div>
            </div>
            {{#if row.hasChildren}}
              <button
                type="button"
                class="icon-btn inventory-row-toggle {{#if row.isCollapsed}}is-collapsed{{/if}}"
                data-action="inventory-row-toggle"
                data-inventory-row-key="{{row.key}}"
                title="{{#if row.isCollapsed}}{{localize 'SPACEHOLDER.Inventory.ExpandItem'}}{{else}}{{localize 'SPACEHOLDER.Inventory.CollapseItem'}}{{/if}}"
              >
                <i class="fa-solid fa-chevron-down"></i>
              </button>
            {{/if}}
          </div>
        {{/each}}
        {{#unless inventoryRows.length}}
          <div class='empty-inventory'>
            <i class='fas fa-box-open'></i>
            <p><em>{{localize 'SPACEHOLDER.Inventory.Empty'}}</em></p>
          </div>
        {{/unless}}
      </div>

      <footer class="inventory-stats inventory-footer">
        <div class="inventory-stat">
          <i class="fas fa-weight-hanging"></i>
          <span class="stat-label">{{localize 'SPACEHOLDER.Inventory.TotalWeight'}}</span>
          <span class="stat-value">{{totalWeight}} {{localize 'SPACEHOLDER.Units.Kg'}}</span>
        </div>
        <div class="inventory-stat">
          <i class="fas fa-boxes"></i>
          <button type="button" class="inventory-stat-button" data-action="inventory-debug-open" title="{{localize 'SPACEHOLDER.Inventory.DebugOpenTooltip'}}">
            <span class="stat-label">{{localize 'SPACEHOLDER.Inventory.TotalItems'}}</span>
            <span class="stat-value">{{totalItems}}</span>
          </button>
        </div>
      </footer>
    </section>
  </div>
</div>
