<div class="stats-panel spaceholder-aiming-arc-panel">
  <h3 class="spaceholder-aiming-arc-panel__title">{{localize "SPACEHOLDER.AimingArc.PanelTitle"}}</h3>
  <p class="spaceholder-aiming-arc-panel__hint">{{localize "SPACEHOLDER.AimingArc.PanelHint"}}</p>

  <div class="spaceholder-aiming-arc-grid">
    <div class="spaceholder-aiming-arc-row">
      <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.AimingArc.Zones.Purple"}}</span>
      <span class="spaceholder-aiming-arc-row__value">{{numberFormat system.aimingArc.zoneHalfDegrees.[0] decimals=1}}&deg;</span>
    </div>
    <div class="spaceholder-aiming-arc-row">
      <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.AimingArc.Zones.Green"}}</span>
      <span class="spaceholder-aiming-arc-row__value">{{numberFormat system.aimingArc.zoneHalfDegrees.[1] decimals=1}}&deg;</span>
    </div>
    <div class="spaceholder-aiming-arc-row">
      <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.AimingArc.Zones.Yellow"}}</span>
      <span class="spaceholder-aiming-arc-row__value">{{numberFormat system.aimingArc.zoneHalfDegrees.[2] decimals=1}}&deg;</span>
    </div>
    <div class="spaceholder-aiming-arc-row">
      <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.AimingArc.Zones.Orange"}}</span>
      <span class="spaceholder-aiming-arc-row__value">{{numberFormat system.aimingArc.zoneHalfDegrees.[3] decimals=1}}&deg;</span>
    </div>
    <div class="spaceholder-aiming-arc-row">
      <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.AimingArc.Zones.Red"}}</span>
      <span class="spaceholder-aiming-arc-row__value">{{numberFormat system.aimingArc.zoneHalfDegrees.[4] decimals=1}}&deg;</span>
    </div>
  </div>

  <div class="spaceholder-aiming-arc-row spaceholder-aiming-arc-row--deviation">
    <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.AimingArc.BaseDeviation"}}</span>
    <span class="spaceholder-aiming-arc-row__value">{{numberFormat system.aimingArc.deviationBaseDeg decimals=1}}&deg;</span>
  </div>
  {{#if editable}}
  <button type="button" class="icon-btn spaceholder-aiming-arc-panel__edit" data-action="sh-aiming-arc-edit">
    <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
    <span>{{localize "SPACEHOLDER.AimingArc.EditButton"}}</span>
  </button>
  {{/if}}
  <p class="spaceholder-aiming-arc-panel__hint spaceholder-aiming-arc-panel__hint--small">{{localize "SPACEHOLDER.AimingArc.DeviationHint"}}</p>
</div>
