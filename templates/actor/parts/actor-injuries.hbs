{{!-- Injuries Tab Content --}}
<div class="injuries-container">
  <div class="injuries-panel">
    <div class="injuries-actions">
      <button type="button" class="injury-create-open-btn" data-action="injury-open-create">
        <i class="fas fa-plus"></i> <span class="btn-text">{{localize 'SPACEHOLDER.Injuries.Add'}}</span>
      </button>
    </div>

    <div class="injuries-list">
      {{#if injuriesList}}
        {{#each injuriesList as |inj|}}
          <div class="injury-card" data-injury-id="{{inj.id}}" data-injury-type="{{inj.type}}" data-injury-status="{{inj.status}}">
            <div class="injury-main">
              {{#if inj.hasDescription}}
                {{> "systems/spaceholder/templates/actor/parts/injury/injury-description.hbs" segments=inj.segments tooltipSegments=inj.tooltipSegments}}
              {{else}}
                <span class="injury-line injury-line-fallback">
                  {{inj.partName}}, {{inj.amountDisplay}}{{#if inj.type}}, {{inj.type}}{{/if}}
                </span>
              {{/if}}
              <span class="injury-amount-badge" title="{{localize 'SPACEHOLDER.Injuries.Fields.Damage'}}">{{inj.amountDisplay}}</span>
              {{#if inj.createdAtText}}
                <i class="fas fa-clock injury-when" title="{{inj.createdAtText}}"></i>
              {{/if}}
            </div>
            <div class="injury-actions">
              <button type="button" class="icon-btn injury-edit-btn" data-action="injury-edit" data-injury-id="{{inj.id}}" title="{{localize 'SPACEHOLDER.Actions.Edit'}}"><i class="fas fa-pen"></i></button>
              <button type="button" class="icon-btn injury-delete-btn" data-action="injury-delete" data-injury-id="{{inj.id}}" title="{{localize 'SPACEHOLDER.Actions.Delete'}}"><i class="fas fa-trash"></i></button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p><em>{{localize 'SPACEHOLDER.Injuries.Empty'}}</em></p>
      {{/if}}
    </div>
  </div>
</div>
