{{!-- Health Tab Content --}}
<div class="health-container">

  {{!-- Верх: одна строка — название анатомии слева, кнопки справа --}}
  <div class="anatomy-management-container">
    <div class="anatomy-management-row">
      <button type="button" class="anatomy-current-btn{{#unless hasAnatomy}} anatomy-current-btn--empty{{/unless}}" {{#unless editable}}disabled{{/unless}}>
        {{#if hasAnatomy}}
          {{anatomyDisplayName}}
        {{else}}
          Не выбрана
        {{/if}}
      </button>
      <span class="anatomy-management-spacer"></span>
      <div class="anatomy-actions">
      <span class="anatomy-actions-sep"></span>
      <button type="button" class="anatomy-icon-btn anatomy-editor-link-mode-btn" title="Режим связей: перетащите часть на другую часть для создания связи">
        <i class="fas fa-link"></i>
      </button>
      <button type="button" class="anatomy-icon-btn anatomy-editor-add-part-btn" title="Добавить часть тела">
        <i class="fas fa-plus"></i>
      </button>
      <button type="button" class="anatomy-icon-btn anatomy-editor-grid-btn" title="Размер сетки анатомии">
        <i class="fas fa-th-large"></i>
      </button>
      <button type="button" class="anatomy-icon-btn anatomy-editor-edit-btn" title="Режим редактирования: перемещение, добавление и удаление частей">
        <i class="fas fa-edit"></i>
      </button>
      </div>
    </div>
  </div>

  <div class="health-main-layout">
    {{!-- Колонка 1: экипированные предметы и покрытие частей тела --}}
    <div class="health-equipment-column">
      <div class="health-equipment-panel">
        <div class="health-equipment-panel-title">{{localize "SPACEHOLDER.Health.EquippedColumn.Title"}}</div>
        {{#if healthEquipped.hasRows}}
          <div class="health-equipment-list">
            {{#each healthEquipped.rows as |gear|}}
              <article
                class="health-equipment-card"
                data-item-id="{{gear.id}}"
                data-action="sh-health-equipped-open"
                role="button"
                tabindex="0"
                title="{{gear.name}}"
              >
                <div class="health-equipment-card__head">
                  <div class="health-equipment-card__image">
                    <img src="{{gear.img}}" alt="" width="36" height="36" />
                  </div>
                  <div class="health-equipment-card__titles">
                    <span class="health-equipment-card__name">{{gear.name}}</span>
                    <div class="health-equipment-card__tags">
                      {{#if gear.isArmor}}
                        <span class="health-equipment-tag health-equipment-tag--armor">{{localize "SPACEHOLDER.Health.EquippedColumn.TagArmor"}}</span>
                      {{/if}}
                      {{#if gear.isModifiers}}
                        <span class="health-equipment-tag health-equipment-tag--modifiers">{{localize "SPACEHOLDER.Health.EquippedColumn.TagModifiers"}}</span>
                      {{/if}}
                    </div>
                  </div>
                </div>
                {{#if gear.showNoMatchingPartsHint}}
                  <p class="health-equipment-hint health-equipment-hint--warn">{{localize "SPACEHOLDER.Health.EquippedColumn.NoMatchingParts"}}</p>
                {{/if}}
                {{#if gear.coverageLines.length}}
                  <ul class="health-equipment-coverage">
                    {{#each gear.coverageLines as |line|}}
                      <li class="health-equipment-coverage__row">
                        <span class="health-equipment-coverage__part">{{line.partName}}</span>
                        {{#if ../isArmor}}
                          <span class="health-equipment-coverage__val">
                            <i class="fas fa-shield-alt" aria-hidden="true"></i>
                            {{line.armorValue}}
                          </span>
                        {{/if}}
                      </li>
                    {{/each}}
                  </ul>
                {{else}}
                  {{#if gear.showNoCoverageHint}}
                    <p class="health-equipment-hint">{{localize "SPACEHOLDER.Health.EquippedColumn.NoCoverage"}}</p>
                  {{/if}}
                {{/if}}
              </article>
            {{/each}}
          </div>
        {{else}}
          <p class="health-equipment-empty">{{localize "SPACEHOLDER.Health.EquippedColumn.NoGear"}}</p>
        {{/if}}
      </div>
    </div>

    {{!-- Колонка 2: только визуализация --}}
    <div class="health-anatomy-editor-column">
      <div class="anatomy-editor-wrap anatomy-editor-wrap--fixed">
        <div class="anatomy-editor-container" data-anatomy-editor="container"></div>
      </div>
    </div>

    {{!-- Колонка 3: список частей тела --}}
    <div class="health-bodyparts-column">
      <div class="body-parts-hierarchy">
        {{#if hierarchicalBodyParts}}
        <div class="parts-tree">
{{#each hierarchicalBodyParts as |part|}}
          <div class="body-part-line status-{{part.status}} {{#if part.isInjured}}injured{{else}}healthy{{/if}}" data-part-id="{{part.id}}" role="button" tabindex="0">
            <span class="tree-structure">{{part.treePrefix}}</span><span class="part-name">{{part.name}}</span>
            <span class="part-spacer"></span>
            {{#if part.armor}}
            <span class="part-armor">
              <i class="fas fa-shield-alt"></i> {{part.armor}}
            </span>
            {{/if}}
            <span class="health-numbers">{{part.currentHp}}/{{part.maxHp}}</span>
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="no-body-parts">
          <p><em>No body parts data available</em></p>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Указатель линия список <-> круг (при наведении); цепляется слева от имени в списке --}}
    <div class="health-anatomy-pointer-overlay" aria-hidden="true">
      <svg class="health-anatomy-pointer-svg">
        <line class="health-anatomy-pointer-line" x1="0" y1="0" x2="0" y2="0"/>
      </svg>
    </div>
  </div>

  {{!-- Панель просмотра части тела: на всю ширину, под тремя колонками; внутри — три колонки: защита | общая информация | органы --}}
  <div class="anatomy-editor-selected-panel anatomy-editor-selected-panel--fullwidth" data-anatomy-editor="panel"></div>

</div>
