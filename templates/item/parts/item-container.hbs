<div class="inventory-panel spaceholder-item-container-panel" data-sh-item-container-drop="1" data-container-host-id="{{item._id}}">
  {{#if containerUsesNestedStorage}}
  <div class="inventory-list spaceholder-item-container-list spaceholder-item-storage-list" data-sh-item-storage-drop="1">
    {{#each containerStorageRows as |sitem|}}
      <div class="inventory-item-card item-container-item-card inventory-item-card--nested inventory-item-card--storage-snapshot" style="--sh-inv-depth: {{sitem.depth}}" data-nested-path="{{sitem.path}}">
        <div class="item-main">
          <div class="item-image">
            <img src="{{sitem.img}}" title="{{sitem.name}}" width="32" height="32" alt="" />
          </div>
          <div class="item-info">
            <div class="item-name">{{sitem.name}}</div>
            {{#if sitem.system.description}}
              <div class="item-description">{{sitem.system.description}}</div>
            {{/if}}
            <div class="item-details">
              <span class="item-storage-kind">{{localize 'SPACEHOLDER.Inventory.NestedStorageItem'}}</span>
              <span class="item-quantity">{{localize 'SPACEHOLDER.Inventory.Quantity'}} {{sitem.quantity}}</span>
              <span class="item-weight">{{localize 'SPACEHOLDER.Inventory.ItemTotalWeight'}} {{numberFormat sitem.totalWeight decimals=2}} {{localize 'SPACEHOLDER.Units.Kg'}}</span>
            </div>
          </div>
        </div>
        <div class="item-controls">
          {{#unless ../containerReadOnly}}
          {{#if ../containerOnActor}}
          <button type="button" class="icon-btn" title="{{localize 'SPACEHOLDER.ItemContainer.Extract'}}" data-action="sh-item-storage-extract" data-nested-path="{{sitem.path}}">
            <i class="fas fa-box-open"></i>
          </button>
          {{/if}}
          <button type="button" class="icon-btn item-delete" title="{{localize 'SPACEHOLDER.Inventory.DeleteItem'}}" data-action="sh-item-storage-delete" data-nested-path="{{sitem.path}}">
            <i class="fas fa-trash"></i>
          </button>
          {{/unless}}
        </div>
      </div>
    {{/each}}
    {{#unless containerStorageRows.length}}
      <div class="empty-inventory spaceholder-item-container-empty">
        <i class="fas fa-box-open"></i>
        <p><em>{{localize 'SPACEHOLDER.ItemContainer.MagazineEmpty'}}</em></p>
        {{#unless containerReadOnly}}
        <p class="spaceholder-item-container-drop-hint"><em>{{localize 'SPACEHOLDER.ItemContainer.MagazineDropHint'}}</em></p>
        {{/unless}}
      </div>
    {{/unless}}
  </div>

  {{> "systems/spaceholder/templates/item/parts/item-container-footer.hbs"}}

  {{else}}
  {{#if containerWorldMode}}
  <p class="spaceholder-item-container-hint"><em>{{localize 'SPACEHOLDER.ItemContainer.WorldModeHint'}}</em></p>

  <div class="inventory-list spaceholder-item-container-list">
    {{#each containerGear as |citem|}}
      <div class="inventory-item-card item-container-item-card {{#if citem.broken}}spaceholder-item-container-broken{{/if}}" data-entry-kind="world" data-world-uuid="{{citem.worldUuid}}" draggable="{{#if ../containerReadOnly}}false{{else}}true{{/if}}">
        <div class="item-main">
          <div class="item-image">
            <img src="{{citem.img}}" title="{{citem.name}}" width="32" height="32" alt="" />
          </div>
          <div class="item-info">
            <div class="item-name">{{citem.name}}</div>
            {{#if citem.system.description}}
              <div class="item-description">{{citem.system.description}}</div>
            {{/if}}
            <div class="item-details">
              {{#if citem.system.quantity}}
                <span class="item-quantity">{{localize 'SPACEHOLDER.Inventory.Quantity'}} {{citem.system.quantity}}</span>
              {{/if}}
              {{#if citem.system.weight}}
                <span class="item-weight">{{localize 'SPACEHOLDER.Inventory.ItemTotalWeight'}} {{numberFormat (multiply citem.system.weight citem.system.quantity) decimals=2}} {{localize 'SPACEHOLDER.Units.Kg'}}</span>
              {{/if}}
            </div>
          </div>
        </div>
        <div class="item-controls">
          {{#unless ../containerReadOnly}}
          {{#unless citem.broken}}
          <button type="button" class="icon-btn item-edit" title="{{localize 'SPACEHOLDER.Inventory.EditItem'}}" data-action="sh-item-container-edit-world" data-world-uuid="{{citem.worldUuid}}">
            <i class="fas fa-edit"></i>
          </button>
          {{/unless}}
          <button type="button" class="icon-btn" title="{{localize 'SPACEHOLDER.ItemContainer.WorldExtractHint'}}" disabled aria-disabled="true">
            <i class="fas fa-box-open"></i>
          </button>
          <button type="button" class="icon-btn item-delete" title="{{localize 'SPACEHOLDER.ItemContainer.Unlink'}}" data-action="sh-item-container-unlink" data-world-uuid="{{citem.worldUuid}}">
            <i class="fas fa-unlink"></i>
          </button>
          {{else}}
          {{#unless citem.broken}}
          <button type="button" class="icon-btn item-edit" title="{{localize 'SPACEHOLDER.Inventory.EditItem'}}" data-action="sh-item-container-edit-world" data-world-uuid="{{citem.worldUuid}}">
            <i class="fas fa-edit"></i>
          </button>
          {{/unless}}
          {{/unless}}
        </div>
      </div>
    {{/each}}
    {{#unless containerGear.length}}
      <div class="empty-inventory spaceholder-item-container-empty">
        <i class="fas fa-box-open"></i>
        <p><em>{{localize 'SPACEHOLDER.ItemContainer.Empty'}}</em></p>
        {{#unless containerReadOnly}}
        <p class="spaceholder-item-container-drop-hint"><em>{{localize 'SPACEHOLDER.ItemContainer.WorldDropHint'}}</em></p>
        {{/unless}}
      </div>
    {{/unless}}
  </div>

  {{> "systems/spaceholder/templates/item/parts/item-container-footer.hbs"}}

  {{else if containerOnActor}}
  <div class="inventory-list spaceholder-item-container-list">
    {{#each containerGear as |citem|}}
      <div class="inventory-item-card item-container-item-card" data-entry-kind="actor" data-item-id="{{citem._id}}" draggable="{{#if ../containerReadOnly}}false{{else}}true{{/if}}">
        <div class="item-main">
          <div class="item-image">
            <img src="{{citem.img}}" title="{{citem.name}}" width="32" height="32" alt="" />
          </div>
          <div class="item-info">
            <div class="item-name">{{citem.name}}</div>
            {{#if citem.system.description}}
              <div class="item-description">{{citem.system.description}}</div>
            {{/if}}
            <div class="item-details">
              {{#if citem.system.quantity}}
                <span class="item-quantity">{{localize 'SPACEHOLDER.Inventory.Quantity'}} {{citem.system.quantity}}</span>
              {{/if}}
              {{#if citem.system.weight}}
                <span class="item-weight">{{localize 'SPACEHOLDER.Inventory.ItemTotalWeight'}} {{numberFormat (multiply citem.system.weight citem.system.quantity) decimals=2}} {{localize 'SPACEHOLDER.Units.Kg'}}</span>
              {{/if}}
            </div>
          </div>
        </div>
        <div class="item-controls">
          {{#unless ../containerReadOnly}}
          <button type="button" class="icon-btn item-edit" title="{{localize 'SPACEHOLDER.Inventory.EditItem'}}" data-action="sh-item-container-edit" data-item-id="{{citem._id}}">
            <i class="fas fa-edit"></i>
          </button>
          <button type="button" class="icon-btn" title="{{localize 'SPACEHOLDER.ItemContainer.Extract'}}" data-action="sh-item-container-extract" data-item-id="{{citem._id}}">
            <i class="fas fa-box-open"></i>
          </button>
          <button type="button" class="icon-btn item-delete" title="{{localize 'SPACEHOLDER.Inventory.DeleteItem'}}" data-action="sh-item-container-delete" data-item-id="{{citem._id}}">
            <i class="fas fa-trash"></i>
          </button>
          {{else}}
          <button type="button" class="icon-btn item-edit" title="{{localize 'SPACEHOLDER.Inventory.EditItem'}}" data-action="sh-item-container-edit" data-item-id="{{citem._id}}">
            <i class="fas fa-edit"></i>
          </button>
          {{/unless}}
        </div>
      </div>
    {{/each}}
    {{#unless containerGear.length}}
      <div class="empty-inventory spaceholder-item-container-empty">
        <i class="fas fa-box-open"></i>
        <p><em>{{localize 'SPACEHOLDER.ItemContainer.Empty'}}</em></p>
        {{#unless containerReadOnly}}
        <p class="spaceholder-item-container-drop-hint"><em>{{localize 'SPACEHOLDER.ItemContainer.DropHint'}}</em></p>
        {{/unless}}
      </div>
    {{/unless}}
  </div>

  {{> "systems/spaceholder/templates/item/parts/item-container-footer.hbs"}}
  {{/if}}
  {{/if}}
</div>
