<div class="spaceholder-weapon-tab-layout" data-sh-weapon-channel="{{channelKey}}">
  <div class="spaceholder-weapon-tab-layout__stats flexcol">
    <div class="stats-panel spaceholder-aiming-arc-panel sh-weapon-channel-panel">
      <h3 class="spaceholder-aiming-arc-panel__title">{{localize "SPACEHOLDER.ItemWeapon.GroupFeatures"}}</h3>
      <div class="spaceholder-aiming-arc-grid">
        {{#each ch.featuresRows as |row|}}
          <div class="spaceholder-aiming-arc-row">
            <span class="spaceholder-aiming-arc-row__label">{{row.label}}</span>
            <span class="spaceholder-aiming-arc-row__value{{#if row.text}} sh-weapon-value--text{{/if}}">{{row.display}}</span>
          </div>
        {{/each}}
      </div>
      {{#if @root.editable}}
      <button type="button" class="icon-btn spaceholder-aiming-arc-panel__edit" data-action="sh-weapon-edit-features" data-channel="{{channelKey}}">
        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
        <span>{{localize "SPACEHOLDER.ItemWeapon.EditFeatures"}}</span>
      </button>
      {{/if}}
    </div>

    <div class="stats-panel spaceholder-aiming-arc-panel sh-weapon-channel-panel">
      <h3 class="spaceholder-aiming-arc-panel__title">{{localize "SPACEHOLDER.ItemWeapon.GroupProjectile"}}</h3>
      <div class="spaceholder-aiming-arc-grid">
        {{#each ch.projectileRows as |row|}}
          <div class="spaceholder-aiming-arc-row">
            <span class="spaceholder-aiming-arc-row__label">{{row.label}}</span>
            <span class="spaceholder-aiming-arc-row__value{{#if row.text}} sh-weapon-value--text{{/if}}">{{row.display}}</span>
          </div>
        {{/each}}
      </div>
      {{#if @root.editable}}
      <button type="button" class="icon-btn spaceholder-aiming-arc-panel__edit" data-action="sh-weapon-edit-projectile" data-channel="{{channelKey}}">
        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
        <span>{{localize "SPACEHOLDER.ItemWeapon.EditProjectile"}}</span>
      </button>
      {{/if}}
    </div>

    <div class="stats-panel spaceholder-aiming-arc-panel sh-weapon-channel-panel">
      <h3 class="spaceholder-aiming-arc-panel__title">{{localize "SPACEHOLDER.ItemWeapon.GroupUsage"}}</h3>
      <div class="spaceholder-aiming-arc-grid">
        {{#each ch.usageRows as |row|}}
          <div class="spaceholder-aiming-arc-row{{#if row.multiline}} spaceholder-aiming-arc-row--deviation{{/if}}">
            <span class="spaceholder-aiming-arc-row__label">{{row.label}}</span>
            <span class="spaceholder-aiming-arc-row__value{{#if row.text}} sh-weapon-value--text{{/if}}{{#if row.multiline}} sh-weapon-value--multiline{{/if}}">{{row.display}}</span>
          </div>
        {{/each}}
      </div>
      {{#if @root.editable}}
      <button type="button" class="icon-btn spaceholder-aiming-arc-panel__edit" data-action="sh-weapon-edit-usage" data-channel="{{channelKey}}">
        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
        <span>{{localize "SPACEHOLDER.ItemWeapon.EditUsage"}}</span>
      </button>
      {{/if}}
    </div>

    {{#if (eq channelKey "ranged")}}
    <div class="stats-panel spaceholder-aiming-arc-panel sh-weapon-channel-panel">
      <div class="sh-weapon-attacks-toolbar">
        <h3 class="spaceholder-aiming-arc-panel__title">{{localize "SPACEHOLDER.ItemWeapon.NestedStorageTitle"}}</h3>
        {{#if @root.editable}}
        <button type="button" class="icon-btn" data-action="sh-nested-storage-add" title='{{localize "SPACEHOLDER.ItemWeapon.NestedAddTitle"}}'>
          <i class="fas fa-plus" aria-hidden="true"></i>
        </button>
        {{/if}}
      </div>
      <div class="spaceholder-aiming-arc-grid">
        <div class="spaceholder-aiming-arc-row">
          <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.ItemWeapon.AttachedContainerId"}}</span>
          <span class="spaceholder-aiming-arc-row__value sh-weapon-value--text">{{#if ch.nestedStorage.attachedContainerId}}{{ch.nestedStorage.attachedContainerId}}{{else}}—{{/if}}</span>
        </div>
        <div class="spaceholder-aiming-arc-row">
          <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.ItemWeapon.AmmoChamberCurrentId"}}</span>
          <span class="spaceholder-aiming-arc-row__value sh-weapon-value--text">{{#if ch.nestedStorage.chamberItemId}}{{ch.nestedStorage.chamberItemId}}{{else}}—{{/if}}</span>
        </div>
      </div>
      {{#if ch.nestedStorage.contents.length}}
        <div class="sh-weapon-attacks-grid">
          {{#each ch.nestedStorage.contents as |entry|}}
            <div class="sh-weapon-attack-summary">
              <div class="sh-weapon-attack-summary__text">
                <div class="sh-weapon-attack-summary__name">{{entry.name}} ×{{entry.quantity}}</div>
                <div class="sh-weapon-attack-summary__meta">
                  {{entry.path}}{{#if entry.isAttached}} · {{localize "SPACEHOLDER.ItemWeapon.NestedAttached"}}{{/if}}{{#if entry.isChamber}} · {{localize "SPACEHOLDER.ItemWeapon.NestedChamber"}}{{/if}}{{#if entry.childCount}} · {{entry.childCount}} nested{{/if}}
                </div>
              </div>
              {{#if @root.editable}}
              <div class="sh-weapon-attack-summary__actions">
                <button type="button" class="icon-btn" data-action="sh-nested-storage-set-attached" data-path="{{entry.path}}" title='{{localize "SPACEHOLDER.ItemWeapon.SetAttachedContainer"}}'>
                  <i class="fas fa-link" aria-hidden="true"></i>
                </button>
                {{#if entry.isAmmo}}
                <button type="button" class="icon-btn" data-action="sh-nested-storage-set-chamber" data-path="{{entry.path}}" title='{{localize "SPACEHOLDER.ItemWeapon.SetChamberItem"}}'>
                  <i class="fas fa-bullseye" aria-hidden="true"></i>
                </button>
                {{/if}}
                <button type="button" class="icon-btn" data-action="sh-nested-storage-extract" data-path="{{entry.path}}" title='{{localize "SPACEHOLDER.ItemWeapon.NestedExtract"}}'>
                  <i class="fas fa-arrow-up-from-bracket" aria-hidden="true"></i>
                </button>
              </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="spaceholder-aiming-arc-panel__hint sh-weapon-attacks-empty">{{localize "SPACEHOLDER.ItemWeapon.NestedStorageEmpty"}}</p>
      {{/if}}
      <p class="spaceholder-aiming-arc-panel__hint">{{localize "SPACEHOLDER.ItemWeapon.NestedFeedSourcesHint"}}: {{ch.nestedStorage.feedSources}}</p>
    </div>
    {{/if}}

    <div class="stats-panel spaceholder-aiming-arc-panel sh-weapon-channel-panel">
      <h3 class="spaceholder-aiming-arc-panel__title">{{localize "SPACEHOLDER.ItemWeapon.ChannelOptions"}}</h3>
      <div class="spaceholder-aiming-arc-grid">
        <div class="spaceholder-aiming-arc-row">
          <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.ItemWeapon.DefaultAttackId"}}</span>
          <span class="spaceholder-aiming-arc-row__value sh-weapon-value--text">{{#if ch.defaultAttackId}}{{ch.defaultAttackId}}{{else}}—{{/if}}</span>
        </div>
        <div class="spaceholder-aiming-arc-row">
          <span class="spaceholder-aiming-arc-row__label">{{localize "SPACEHOLDER.ItemWeapon.AutoGenerateDefault"}}</span>
          <span class="spaceholder-aiming-arc-row__value">{{#if ch.autoGenerateDefault}}{{localize "SPACEHOLDER.ItemWeapon.Yes"}}{{else}}{{localize "SPACEHOLDER.ItemWeapon.No"}}{{/if}}</span>
        </div>
      </div>
      {{#if @root.editable}}
      <button type="button" class="icon-btn spaceholder-aiming-arc-panel__edit" data-action="sh-weapon-edit-channel-options" data-channel="{{channelKey}}">
        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
        <span>{{localize "SPACEHOLDER.ItemWeapon.EditChannelOptions"}}</span>
      </button>
      {{/if}}
    </div>
  </div>

  <div class="spaceholder-weapon-tab-layout__attacks flexcol">
    <div class="stats-panel spaceholder-aiming-arc-panel sh-weapon-attacks-panel">
      <div class="sh-weapon-attacks-toolbar">
        <h3 class="spaceholder-aiming-arc-panel__title sh-weapon-attacks-panel__title">{{localize "SPACEHOLDER.ItemWeapon.Attacks"}}</h3>
        {{#if @root.editable}}
        <button type="button" class="icon-btn" data-action="sh-weapon-attack-add" data-channel="{{channelKey}}" title='{{localize "SPACEHOLDER.ItemWeapon.AddAttack"}}'>
          <i class="fas fa-plus" aria-hidden="true"></i>
        </button>
        {{/if}}
      </div>
      <div class="spaceholder-aiming-arc-grid sh-weapon-attacks-grid">
        {{#if ch.attacks.length}}
          {{#each ch.attacks as |atk|}}
            <div class="sh-weapon-attack-summary">
              <div class="sh-weapon-attack-summary__text">
                <div class="sh-weapon-attack-summary__name">{{#if atk.name}}{{atk.name}}{{else}}<em>{{localize "SPACEHOLDER.ItemWeapon.UntitledAttack"}}</em>{{/if}}</div>
                <div class="sh-weapon-attack-summary__meta">{{atk.mode}} · {{atk.origin}}{{#if atk.isDefault}} · {{localize "SPACEHOLDER.ItemWeapon.Default"}}{{/if}}{{#unless atk.enabled}} · {{localize "SPACEHOLDER.ItemWeapon.Disabled"}}{{/unless}}</div>
              </div>
              {{#if @root.editable}}
              <div class="sh-weapon-attack-summary__actions">
                <button type="button" class="icon-btn" data-action="sh-weapon-attack-edit" data-channel="{{../channelKey}}" data-attack-id="{{atk.id}}" title='{{localize "SPACEHOLDER.Actions.Edit"}}'>
                  <i class="fas fa-pen" aria-hidden="true"></i>
                </button>
                <button type="button" class="icon-btn" data-action="sh-weapon-attack-duplicate" data-channel="{{../channelKey}}" data-attack-id="{{atk.id}}" title='{{localize "SPACEHOLDER.ActionsSystem.UI.DuplicateAction"}}'>
                  <i class="fas fa-copy" aria-hidden="true"></i>
                </button>
                <button type="button" class="icon-btn" data-action="sh-weapon-attack-remove" data-channel="{{../channelKey}}" data-attack-id="{{atk.id}}" title='{{localize "SPACEHOLDER.Actions.Delete"}}'>
                  <i class="fas fa-trash" aria-hidden="true"></i>
                </button>
              </div>
              {{/if}}
            </div>
          {{/each}}
        {{else}}
          <p class="spaceholder-aiming-arc-panel__hint sh-weapon-attacks-empty">{{localize "SPACEHOLDER.ItemWeapon.AttacksEmpty"}}</p>
        {{/if}}
      </div>
    </div>
  </div>
</div>
