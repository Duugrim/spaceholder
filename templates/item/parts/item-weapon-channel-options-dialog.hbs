<div class="sh-item-action-dialog sh-weapon-edit-dialog" data-sh-weapon-channel-options-dialog="{{dialogUid}}">
  <div class="form-group">
    <label>{{localize "SPACEHOLDER.ItemWeapon.DefaultAttackId"}}</label>
    <div class="form-fields">
      <input type="text" name="wo_defaultAttackId" value="{{ch.defaultAttackId}}" placeholder='{{localize "SPACEHOLDER.ItemWeapon.DefaultAttackIdHint"}}' />
    </div>
  </div>
  <div class="sh-item-action-dialog__flags">
    <label class="sh-custom-action-flag">
      <input type="checkbox" name="wo_autoGenerateDefault" {{#if ch.autoGenerateDefault}}checked{{/if}} />
      <span>{{localize "SPACEHOLDER.ItemWeapon.AutoGenerateDefault"}}</span>
    </label>
  </div>
</div>
